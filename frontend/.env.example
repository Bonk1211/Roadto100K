# ==========================================
# SafeSend Environment Variables (.env.example)
# ==========================================
# This file contains the template for all environment variables
# required across the SafeSend monorepo (React apps & AWS/Alibaba mock API).
# Copy this to .env and fill in the values.

# ------------------------------------------
# 1. AWS Configuration (Real-Time Hot Path)
# ------------------------------------------
AWS_REGION="ap-southeast-1"
AWS_ACCESS_KEY_ID="your_aws_access_key_id"
AWS_SECRET_ACCESS_KEY="your_aws_secret_access_key"

# AWS Service Specifics
AWS_DYNAMODB_ALERTS_TABLE="safesend_alerts"
AWS_KINESIS_STREAM_NAME="safesend_events"
AWS_SNS_TOPIC_ARN="arn:aws:sns:ap-southeast-1:123456789012:safesend_notifications"
AWS_BEDROCK_MODEL_ID="anthropic.claude-3-sonnet-20240229-v1:0" # or titan model id

# ------------------------------------------
# 2. Alibaba Cloud Configuration (ML & Storage)
# ------------------------------------------
ALIBABA_CLOUD_REGION="ap-southeast-1"
ALIBABA_ACCESS_KEY_ID="your_alibaba_access_key_id"
ALIBABA_ACCESS_KEY_SECRET="your_alibaba_access_key_secret"

# Alibaba Service Specifics
ALIBABA_EAS_ENDPOINT="https://eas.ap-southeast-1.alicdn.com/api/predict/safesend_model"
ALIBABA_EAS_TOKEN="your_eas_authentication_token"
ALIBABA_OSS_BUCKET_NAME="safesend-training-data"

# ------------------------------------------
# 3. Frontend / Mock API Configuration
# ------------------------------------------
# Port configurations for local development
PORT_MOCK_API=3000
PORT_USER_APP=5173
PORT_AGENT_DASHBOARD=5174
PORT_PLUGIN=5175

# Vite variables for React Apps (must be prefixed with VITE_)
VITE_API_BASE_URL="http://localhost:3000" # Change to AWS API Gateway URL in production
VITE_ENVIRONMENT="development"

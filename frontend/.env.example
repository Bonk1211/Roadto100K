# ==========================================
# SafeSend Environment Variables (.env.example)
# ==========================================
# Frontend monorepo — backed by AWS Lambda + API Gateway.
# Copy this to .env (or per-app .env.local) and fill in the values.

# ------------------------------------------
# 1. AWS Configuration (Real-Time Hot Path)
# ------------------------------------------
AWS_REGION="ap-southeast-1"
AWS_KMS_KEY_ARN="arn:aws:kms:ap-southeast-1:912096797026:key/<key-id>"

# AWS Service Specifics
RDSHOST="<rds-endpoint>.ap-southeast-1.rds.amazonaws.com"
RDSPORT="5432"
RDSDBNAME="postgres"
RDSUSER="postgres"
AWS_KINESIS_STREAM_NAME="safesend_events"
AWS_SNS_TOPIC_ARN="arn:aws:sns:ap-southeast-1:<account>:safesend_notifications"
AWS_BEDROCK_MODEL_ID="anthropic.claude-3-sonnet-20240229-v1:0"

# ------------------------------------------
# 2. Alibaba Cloud Configuration (ML & Storage)
# ------------------------------------------
ALIBABA_CLOUD_REGION="ap-southeast-1"
ALIBABA_ACCESS_KEY_ID="your_alibaba_access_key_id"
ALIBABA_ACCESS_KEY_SECRET="your_alibaba_access_key_secret"
ALIBABA_EAS_ENDPOINT="https://eas.ap-southeast-1.alicdn.com/api/predict/safesend_model"
ALIBABA_EAS_TOKEN="your_eas_authentication_token"
ALIBABA_OSS_BUCKET_NAME="safesend-training-data"

# ------------------------------------------
# 3. Frontend (Vite apps)
# ------------------------------------------
PORT_USER_APP=5173
PORT_PLUGIN=5174
PORT_AGENT_DASHBOARD=5175

# Apps call API Gateway directly. Set this in apps/<name>/.env or .env.local.
VITE_API_URL="https://yognv4d3gl.execute-api.ap-southeast-1.amazonaws.com/prod"
VITE_API_KEY=""              # Optional: x-api-key for protected stages
VITE_ENVIRONMENT="development"
